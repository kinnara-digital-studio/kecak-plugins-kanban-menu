[
  {
    "title": "Kanban Inbox Menu Properties",
    "properties": [
      {
        "name": "id",
        "label": "Id",
        "type": "hidden"
      },
      {
        "name": "customId",
        "label": "Custom ID",
        "type": "textfield",
        "regex_validation": "^[a-zA-Z0-9_]+$",
        "validation_message": "Invalid"
      },
      {
        "name": "label",
        "label": "Label",
        "type": "textfield",
        "required": "true",
        "value": "My Menu"
      },
      {
        "name" : "processDefId",
        "label" : "@@userview.inboxmenu.process@@",
        "type" : "selectbox",
        "required" : "true",
        "options_ajax" : "[CONTEXT_PATH]/web/json/app[APP_PATH]/plugin/%s/service?action=getProcesses"
      },
      {
        "name": "dataListId",
        "label": "DataList",
        "type": "selectbox",
        "options_ajax": "[CONTEXT_PATH]/web/json/console/app[APP_PATH]/datalist/options"
      },{
        "name": "isRunningProcessOnly",
        "label": "Show only running process",
        "type": "checkbox",
        "value": "true",
        "options": [
          {
            "value": "true",
            "label": ""
          }
        ]
      },
      {
        "name": "statusField",
        "label": "Status Field",
        "type": "textfield",
        "required": "true"
      },
      {
        "name": "titleField",
        "label": "Title Field",
        "type": "textfield",
        "required": "true"
      },
      {
        "name": "formDefId",
        "label": "Form",
        "type" : "selectbox",
        "required" : "true",
        "options_ajax" : "[CONTEXT_PATH]/web/json/console/app[APP_PATH]/forms/options"
      }
    ]
  }
]