[
  {
    "title": "Kanban WorkFlow Menu Properties",
    "properties": [
      {
        "name": "id",
        "label": "Id",
        "type": "hidden"
      },
      {
        "name": "customId",
        "label": "Custom ID",
        "type": "textfield",
        "regex_validation": "^[a-zA-Z0-9_]+$",
        "validation_message": "Invalid"
      },
      {
        "name": "label",
        "label": "Label",
        "type": "textfield",
        "required": "true",
        "value": "My Menu"
      },
      {
        "name" : "processDefId",
        "label" : "@@userview.inboxmenu.process@@",
        "type" : "selectbox",
        "required" : "true",
        "options_ajax" : "[CONTEXT_PATH]/web/json/app[APP_PATH]/plugin/%s/service?action=getProcesses"
      },
      {
        "name": "dataListId",
        "label": "DataList",
        "type": "selectbox",
        "required": "true",
        "options_ajax": "[CONTEXT_PATH]/web/json/console/app[APP_PATH]/datalist/options"
      },
      {
        "name": "statusField",
        "label": "Status Field",
        "type": "textfield",
        "required": "true"
      },
      {
        "name": "titleField",
        "label": "Title Field",
        "type": "textfield",
        "required": "true"
      },
      {
        "name": "singleFormCheckBox",
        "label": "Single Form",
        "type": "checkbox",
        "value": "",
        "options": [
          {
            "value": "true",
            "label": ""
          }
        ]
      },
      {
        "name": "formDefId",
        "label": "Form",
        "type" : "selectbox",
        "required" : "true",
        "options_ajax" : "[CONTEXT_PATH]/web/json/console/app[APP_PATH]/forms/options",
        "control_field" : "singleFormCheckBox",
        "control_value" :  "true"
      },
      {
        "name": "options",
        "label": "Board Options",
        "type": "grid",
        "required": "true",
        "columns": [
          {
            "key": "value",
            "label": "Value"
          },
          {
            "key": "label",
            "label": "Label"
          },
          {
            "key": "colour",
            "label": "Colour"
          },
          {
            "key": "formDefId",
            "label": "Form Def Id",
            "type" : "selectbox",
            "required" : "true",
            "options_ajax" : "[CONTEXT_PATH]/web/json/console/app[APP_PATH]/forms/options"
          }
        ]
      }
    ]
  }
]